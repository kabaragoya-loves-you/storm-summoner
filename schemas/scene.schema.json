{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stormsummoner.com/schemas/scene.schema.json",
  "title": "Storm Summoner Scene",
  "description": "Scene configuration for Storm Summoner MIDI controller",
  "type": "object",
  "required": ["name", "touchpads", "button_left", "button_right", "button_both"],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 32,
      "description": "Scene display name"
    },
    "program_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Program change value for this scene (0-127)"
    },
    "bank_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Bank number for this scene (0-127, used when bank_select_mode is enabled)"
    },
    "send_pc_on_load": {
      "type": "boolean",
      "default": true,
      "description": "Send program change when loading this scene"
    },
    "on_load": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions to execute when scene loads (for pedal initialization)"
    },
    "touchwheel_mode": {
      "type": "string",
      "enum": ["buttons", "program_change", "continuous", "set_tempo", "pitch_bend", "aftertouch", "nrpn", "rpn", "double_cc"],
      "default": "buttons",
      "description": "Touchwheel behavior mode"
    },
    "touchwheel_style": {
      "type": "string",
      "enum": ["odometer", "endless", "bipolar"],
      "default": "odometer",
      "description": "Touchwheel style: odometer (~15 positions), endless (full range), bipolar (pitch bend only)"
    },
    "touchwheel": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Touchwheel continuous mapping (for TOUCHWHEEL_MODE_CONTINUOUS)"
    },
    "touchpads": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "description": "Array of 12 touchpad mappings",
      "items": {
        "$ref": "#/definitions/touchpad_mapping"
      }
    },
    "button_left": {
      "$ref": "#/definitions/action_chain"
    },
    "button_right": {
      "$ref": "#/definitions/action_chain"
    },
    "button_both": {
      "$ref": "#/definitions/action_chain"
    },
    "bump": {
      "$ref": "#/definitions/action_chain",
      "description": "Bump sensor action chain"
    },
    "expression": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Expression pedal mapping"
    },
    "cv": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "CV input mapping"
    },
    "proximity": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Proximity sensor mapping"
    },
    "als": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Ambient light sensor mapping"
    },
    "expression_mode": {
      "type": "string",
      "enum": ["expression", "sustain", "sostenuto", "gate", "switch"],
      "default": "expression",
      "description": "Expression jack operating mode"
    },
    "sustain": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sustain events (default: CC64 toggle)"
    },
    "sostenuto": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sostenuto events (default: CC66 toggle)"
    },
    "expr_switch": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for expression switch mode (up to 8 arbitrary actions)"
    },
    "cv_input_mode": {
      "type": "string",
      "enum": ["cv", "clock_sync", "audio", "note"],
      "default": "cv",
      "description": "CV input interpretation mode"
    },
    "note_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage"],
      "default": "fixed",
      "description": "Velocity mode for NOTE input mode"
    },
    "note_fixed_velocity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 127,
      "default": 100,
      "description": "Fixed velocity value for NOTE mode"
    },
    "clock_source": {
      "type": "string",
      "enum": ["internal", "midi", "sync"],
      "default": "internal",
      "description": "Tempo clock source for this scene"
    },
    "clock_standard": {
      "type": "string",
      "enum": ["24ppqn", "16th_note", "beat"],
      "default": "24ppqn",
      "description": "Clock output standard for this scene"
    },
    "time_signature": {
      "type": "object",
      "description": "Time signature for this scene",
      "properties": {
        "numerator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beats per bar"
        },
        "denominator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beat unit (4 = quarter note)"
        }
      }
    }
  },
  "definitions": {
    "continuous_mapping": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "output_type": {
          "type": "string",
          "enum": ["cc", "note"],
          "default": "cc",
          "description": "Output type (cc or note)"
        },
        "cc_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "description": "Primary MIDI CC number (when output_type=cc)"
        },
        "cc_numbers": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 127 },
          "maxItems": 4,
          "description": "Additional CC numbers for simultaneous control (up to 4 total)"
        },
        "base_note": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 60,
          "description": "Base MIDI note, typically middle C (when output_type=note)"
        },
        "note_range": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 24,
          "description": "Range in semitones (when output_type=note)"
        },
        "velocity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 100,
          "description": "Note velocity (when output_type=note)"
        },
        "curve_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "description": "Curve type (0=linear, 1=exp, 2=log, 3=s-curve, etc.)"
        },
        "curve_slope": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Curve intensity (0=gentle, 1=medium, 2=steep)"
        },
        "polarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Polarity (0=unipolar, 1=bipolar, 2=inverted)"
        },
        "min_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 0
        },
        "max_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 127
        },
        "use_idle_value": {
          "type": "boolean",
          "default": false
        },
        "idle_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 64,
          "description": "Idle value (64 for CC bipolar, 60 for NOTE mode)"
        },
        "idle_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "default": 1000
        }
      }
    },
    "touchpad_mapping": {
      "type": "object",
      "required": ["enabled", "actions"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this touchpad is active"
        },
        "actions": {
          "$ref": "#/definitions/action_chain"
        }
      }
    },
    "action_chain": {
      "type": "array",
      "maxItems": 4,
      "description": "Array of actions to execute (max 4)",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "program_next",
            "program_prev",
            "pc",
            "scene_next",
            "scene_prev",
            "scene_set",
            "transport_play",
            "transport_stop",
            "transport_pause",
            "transport_record",
            "transport_toggle",
            "tap",
            "tap_tempo",
            "set_tempo",
            "tempo_inc",
            "tempo_dec",
            "send_cc",
            "send_cc_hold",
            "send_cc_cycle",
            "send_double_cc",
            "send_nrpn",
            "send_rpn",
            "send_note_on",
            "send_note_off",
            "send_pitch_bend",
            "send_aftertouch",
            "send_song_select",
            "send_song_position",
            "send_mmc",
            "randomize_cc",
            "send_clock_start",
            "send_clock_stop",
            "send_clock_continue",
            "send_reset",
            "send_tune_request",
            "confirm_pending",
            "all_notes_off",
            "all_sound_off",
            "sustain",
            "sostenuto"
          ],
          "description": "Action type name"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_cc", "send_cc_hold", "send_cc_cycle", "randomize_cc"]}
            }
          },
          "then": {
            "required": ["cc"],
            "properties": {
              "cc": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI CC number"
              },
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "CC value"
              },
              "value2": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "Second value for toggle"
              },
              "num_values": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of values in cycle"
              },
              "values": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "Values for cycle"
              },
              "current_index": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "default": 0,
                "description": "Current position in cycle"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_note_on", "send_note_off"]}
            }
          },
          "then": {
            "required": ["note"],
            "properties": {
              "note": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI note number"
              },
              "velocity": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "default": 100,
                "description": "Note velocity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "scene_set"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 1,
                "maximum": 128,
                "description": "Scene number (1-128)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "send_song_select"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "Song number (0-127)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "pc"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Program number (0-127 without bank, 0-16383 with bank mode)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_nrpn", "send_rpn"]}
            }
          },
          "then": {
            "required": ["parameter", "value"],
            "properties": {
              "parameter": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "NRPN/RPN parameter number"
              },
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "14-bit value"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "randomize_cc"}
            }
          },
          "then": {
            "required": ["cc_numbers"],
            "properties": {
              "cc_numbers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "CC numbers to randomize (0-127)"
              }
            }
          }
        }
      ]
    }
  }
}

