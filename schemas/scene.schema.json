{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stormsummoner.com/schemas/scene.schema.json",
  "title": "Storm Summoner Scene",
  "description": "Scene configuration for Storm Summoner MIDI controller",
  "type": "object",
  "required": ["name", "touchpads", "button_left", "button_right", "button_both"],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 32,
      "description": "Scene display name"
    },
    "device_id": {
      "type": "string",
      "maxLength": 64,
      "description": "Device slug"
    },
    "program_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Program change value for this scene (0-127)"
    },
    "bank_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Bank number for this scene (0-127, used when bank_select_mode is enabled)"
    },
    "send_pc_on_load": {
      "type": "boolean",
      "default": true,
      "description": "Send program change when loading this scene"
    },
    "on_load": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions to execute when scene loads (for pedal initialization)"
    },
    "touchwheel_mode": {
      "type": "string",
      "enum": ["pads", "program_change", "continuous", "set_tempo", "pitch_bend", "aftertouch", "double_cc"],
      "default": "pads",
      "description": "Touchwheel behavior mode"
    },
    "touchwheel_style": {
      "type": "string",
      "enum": ["odometer", "endless", "bipolar"],
      "default": "odometer",
      "description": "Touchwheel style: odometer (~15 positions), endless (full range), bipolar (pitch bend only)"
    },
    "touchwheel": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Touchwheel continuous mapping (for TOUCHWHEEL_MODE_CONTINUOUS)"
    },
    "touchpads": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "description": "Array of 12 touchpad mappings",
      "items": {
        "$ref": "#/definitions/touchpad_mapping"
      }
    },
    "button_left": {
      "$ref": "#/definitions/action_chain"
    },
    "button_right": {
      "$ref": "#/definitions/action_chain"
    },
    "button_both": {
      "$ref": "#/definitions/action_chain"
    },
    "bump": {
      "$ref": "#/definitions/action_chain",
      "description": "Bump sensor action chain"
    },
    "expression": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Expression pedal mapping"
    },
    "cv": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "CV input mapping"
    },
    "proximity": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Proximity sensor mapping"
    },
    "als": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Ambient light sensor mapping"
    },
    "expression_mode": {
      "type": "string",
      "enum": ["expression", "sustain", "sostenuto", "gate", "switch"],
      "default": "expression",
      "description": "Expression jack operating mode"
    },
    "sustain": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sustain events (default: CC64 toggle)"
    },
    "sostenuto": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sostenuto events (default: CC66 toggle)"
    },
    "expr_switch": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for expression switch mode (up to 8 arbitrary actions)"
    },
    "cv_input_mode": {
      "type": "string",
      "enum": ["cv", "clock_sync", "audio", "note"],
      "default": "cv",
      "description": "CV input interpretation mode"
    },
    "note_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage"],
      "default": "fixed",
      "description": "Velocity mode for NOTE input mode"
    },
    "note_fixed_velocity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 127,
      "default": 100,
      "description": "Fixed velocity value for NOTE mode"
    },
    "bpm": {
      "type": "integer",
      "minimum": 20,
      "maximum": 300,
      "default": 120,
      "description": "Tempo in beats per minute for this scene"
    },
    "clock_source": {
      "type": "string",
      "enum": ["internal", "midi", "sync"],
      "default": "internal",
      "description": "Tempo clock source for this scene"
    },
    "beat_divider": {
      "type": "string",
      "enum": ["quarter", "eighth", "sixteenth"],
      "default": "quarter",
      "description": "Beat division for this scene (what note value triggers beat events)"
    },
    "time_signature": {
      "type": "object",
      "description": "Time signature for this scene",
      "properties": {
        "numerator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beats per bar"
        },
        "denominator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beat unit (4 = quarter note)"
        }
      }
    },
    "use_transport": {
      "type": "boolean",
      "default": false,
      "description": "When true, animation follows transport controls (play/pause/stop). When false, animation always runs at current BPM."
    }
  },
  "definitions": {
    "continuous_mapping": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "output_type": {
          "type": "string",
          "enum": ["cc", "note"],
          "default": "cc",
          "description": "Output type (cc or note)"
        },
        "cc_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "description": "Primary MIDI CC number (when output_type=cc)"
        },
        "cc_numbers": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 127 },
          "maxItems": 4,
          "description": "Additional CC numbers for simultaneous control (up to 4 total)"
        },
        "base_note": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 60,
          "description": "Base MIDI note, typically middle C (when output_type=note)"
        },
        "note_range": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 24,
          "description": "Range in semitones (when output_type=note)"
        },
        "velocity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 100,
          "description": "Note velocity (when output_type=note)"
        },
        "note_latch": {
          "type": "boolean",
          "default": false,
          "description": "When true, notes hold until release timer expires (when output_type=note)"
        },
        "note_release_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 4000,
          "default": 500,
          "description": "Release delay in ms when latch is on (when output_type=note)"
        },
        "polyphony": {
          "type": "string",
          "enum": ["mono", "poly"],
          "default": "mono",
          "description": "Polyphony mode: mono (single voice) or poly (up to 4 voices)"
        },
        "curve_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "description": "Curve type (0=linear, 1=exp, 2=log, 3=s-curve, etc.)"
        },
        "curve_slope": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Curve intensity (0=gentle, 1=medium, 2=steep)"
        },
        "polarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Polarity (0=unipolar, 1=bipolar, 2=inverted)"
        },
        "min_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 0
        },
        "max_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 127
        },
        "use_idle_value": {
          "type": "boolean",
          "default": false
        },
        "idle_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 64,
          "description": "Idle value (64 for CC bipolar, 60 for NOTE mode)"
        },
        "idle_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "default": 1000
        }
      }
    },
    "touchpad_mapping": {
      "type": "object",
      "required": ["enabled", "actions"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this touchpad is active"
        },
        "actions": {
          "$ref": "#/definitions/action_chain"
        }
      }
    },
    "action_chain": {
      "type": "array",
      "maxItems": 4,
      "description": "Array of actions to execute (max 4)",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "preset_inc",
            "preset_dec",
            "preset",
            "preset_hold",
            "preset_cycle",
            "scene_inc",
            "scene_dec",
            "scene",
            "play",
            "stop",
            "pause",
            "record",
            "tap",
            "tap_tempo",
            "set_tempo",
            "tempo_inc",
            "tempo_dec",
            "tempo_hold",
            "tempo_cycle",
            "control_change",
            "control_hold",
            "control_cycle",
            "note",
            "randomize",
            "confirm_pending",
            "reset",
            "sustain",
            "sostenuto",
            "touchwheel",
            "touchwheel_hold",
            "touchwheel_cycle"
          ],
          "description": "Action type name"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {"enum": ["control_change", "control_hold", "control_cycle"]}
            }
          },
          "then": {
            "required": ["cc"],
            "properties": {
              "cc": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single MIDI CC number"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of MIDI CC numbers (multi-CC)"
                  }
                ]
              },
              "value": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single CC value"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of CC values (multi-CC)"
                  }
                ]
              },
              "value2": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single release value for hold"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of release values (multi-CC hold)"
                  }
                ]
              },
              "values": {
                "oneOf": [
                  {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 8,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Cycle values for single CC"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 8,
                      "items": {"type": "integer", "minimum": 0, "maximum": 127}
                    },
                    "description": "Array of cycle values (multi-CC cycle)"
                  }
                ]
              },
              "current_index": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "default": 0,
                "description": "Current position in cycle"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["note"]}
            }
          },
          "then": {
            "required": ["note"],
            "properties": {
              "note": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI note number"
              },
              "velocity": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "default": 100,
                "description": "Note velocity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "scene"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 1,
                "maximum": 128,
                "description": "Scene number (1-128)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Program number (0-127 without bank, 0-16383 with bank mode)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "randomize"}
            }
          },
          "then": {
            "required": ["cc_numbers"],
            "properties": {
              "cc_numbers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "CC numbers to randomize (0-127)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset_hold"}
            }
          },
          "then": {
            "required": ["press_preset", "release_preset"],
            "properties": {
              "press_preset": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Preset to set on press"
              },
              "release_preset": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Preset to set on release"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset_cycle"}
            }
          },
          "then": {
            "required": ["num_presets", "presets"],
            "properties": {
              "num_presets": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of presets in cycle"
              },
              "presets": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 16383
                },
                "description": "Preset values to cycle through"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "tempo_hold"}
            }
          },
          "then": {
            "required": ["press_bpm", "release_bpm"],
            "properties": {
              "press_bpm": {
                "type": "integer",
                "minimum": 20,
                "maximum": 300,
                "description": "Tempo to set on press (BPM)"
              },
              "release_bpm": {
                "type": "integer",
                "minimum": 20,
                "maximum": 300,
                "description": "Tempo to set on release (BPM)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "tempo_cycle"}
            }
          },
          "then": {
            "required": ["num_tempos", "tempos"],
            "properties": {
              "num_tempos": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of tempos in cycle"
              },
              "tempos": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 20,
                  "maximum": 300
                },
                "description": "Tempo values (BPM) to cycle through"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "touchwheel"}
            }
          },
          "then": {
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "description": "User-facing touchwheel mode index (0=Pads, 1=CC, 2=PC, 3=Tempo, 4=Pitch Bend, 5=Aftertouch, 6=Notes, 7=Double CC)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "touchwheel_hold"}
            }
          },
          "then": {
            "required": ["mode", "mode2"],
            "properties": {
              "mode": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "description": "User-facing touchwheel mode index on press"
              },
              "mode2": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "description": "User-facing touchwheel mode index on release"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "touchwheel_cycle"}
            }
          },
          "then": {
            "required": ["num_modes", "modes"],
            "properties": {
              "num_modes": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of modes in cycle"
              },
              "modes": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 7
                },
                "description": "User-facing touchwheel mode indices to cycle through"
              }
            }
          }
        }
      ]
    }
  }
}

