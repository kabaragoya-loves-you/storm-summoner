{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stormsummoner.com/schemas/scene.schema.json",
  "title": "Storm Summoner Scene",
  "description": "Scene configuration for Storm Summoner MIDI controller",
  "type": "object",
  "required": ["name", "touchpads", "button_left", "button_right", "button_both"],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 32,
      "description": "Scene display name"
    },
    "program_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Program change value for this scene"
    },
    "send_pc_on_change": {
      "type": "boolean",
      "default": true,
      "description": "Send program change when entering this scene"
    },
    "on_load": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions to execute when scene loads (for pedal initialization)"
    },
    "touchwheel_mode": {
      "type": "string",
      "enum": ["buttons", "encoder"],
      "default": "buttons",
      "description": "Touchwheel behavior mode"
    },
    "touchpads": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "description": "Array of 12 touchpad mappings",
      "items": {
        "$ref": "#/definitions/touchpad_mapping"
      }
    },
    "button_left": {
      "$ref": "#/definitions/action_chain"
    },
    "button_right": {
      "$ref": "#/definitions/action_chain"
    },
    "button_both": {
      "$ref": "#/definitions/action_chain"
    },
    "expression": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Expression pedal mapping"
    },
    "cv": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "CV input mapping"
    },
    "proximity": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Proximity sensor mapping"
    },
    "als": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Ambient light sensor mapping"
    }
  },
  "definitions": {
    "continuous_mapping": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "cc_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127
        },
        "curve_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "description": "Curve type (0=linear, 1=exp, 2=log, 3=s-curve, etc.)"
        },
        "curve_slope": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Curve intensity (0=gentle, 1=medium, 2=steep)"
        },
        "polarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Polarity (0=unipolar, 1=bipolar, 2=inverted)"
        },
        "min_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 0
        },
        "max_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 127
        },
        "use_idle_value": {
          "type": "boolean",
          "default": false
        },
        "idle_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 64
        },
        "idle_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "default": 1000
        }
      }
    },
    "touchpad_mapping": {
      "type": "object",
      "required": ["enabled", "actions"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this touchpad is active"
        },
        "actions": {
          "$ref": "#/definitions/action_chain"
        }
      }
    },
    "action_chain": {
      "type": "array",
      "maxItems": 4,
      "description": "Array of actions to execute (max 4)",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "program_next",
            "program_prev",
            "program_set",
            "program_bank_set",
            "scene_next",
            "scene_prev",
            "scene_set",
            "transport_play",
            "transport_stop",
            "transport_pause",
            "transport_record",
            "transport_toggle",
            "tap_tempo",
            "tempo_nudge_up",
            "tempo_nudge_down",
            "send_cc",
            "send_cc_toggle",
            "send_cc_cycle",
            "send_double_cc",
            "send_nrpn",
            "send_rpn",
            "send_note_on",
            "send_note_off",
            "send_pc",
            "send_pitch_bend",
            "send_aftertouch",
            "send_poly_aftertouch",
            "send_song_select",
            "send_song_position",
            "send_mmc",
            "randomize_cc",
            "randomize_multi",
            "send_clock_start",
            "send_clock_stop",
            "send_clock_continue",
            "send_reset",
            "send_tune_request",
            "screensaver_toggle",
            "confirm_pending",
            "cancel_pending",
            "all_notes_off",
            "all_sound_off"
          ],
          "description": "Action type name"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_cc", "send_cc_toggle", "send_cc_cycle", "randomize_cc"]}
            }
          },
          "then": {
            "required": ["cc"],
            "properties": {
              "cc": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI CC number"
              },
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "CC value"
              },
              "value2": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "Second value for toggle"
              },
              "num_values": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of values in cycle"
              },
              "values": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "Values for cycle"
              },
              "current_index": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "default": 0,
                "description": "Current position in cycle"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_note_on", "send_note_off", "send_poly_aftertouch"]}
            }
          },
          "then": {
            "required": ["note"],
            "properties": {
              "note": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI note number"
              },
              "velocity": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "default": 100,
                "description": "Note velocity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["program_set", "program_bank_set", "scene_set", "send_pc", "send_song_select"]}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "Program or scene number"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["send_nrpn", "send_rpn"]}
            }
          },
          "then": {
            "required": ["parameter", "value"],
            "properties": {
              "parameter": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "NRPN/RPN parameter number"
              },
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "14-bit value"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "randomize_multi"}
            }
          },
          "then": {
            "required": ["num_ccs", "cc_numbers", "min_values", "max_values"],
            "properties": {
              "num_ccs": {
                "type": "integer",
                "minimum": 1,
                "maximum": 8,
                "description": "Number of CCs to randomize"
              },
              "cc_numbers": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "CC numbers to randomize"
              },
              "min_values": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "Minimum value for each CC"
              },
              "max_values": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "Maximum value for each CC"
              }
            }
          }
        }
      ]
    }
  }
}

