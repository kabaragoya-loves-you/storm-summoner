{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stormsummoner.com/schemas/scene.schema.json",
  "title": "Storm Summoner Scene",
  "description": "Scene configuration for Storm Summoner MIDI controller",
  "type": "object",
  "required": ["name", "touchpads", "button_left", "button_right", "button_both"],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 16,
      "description": "Scene display name"
    },
    "ui_module": {
      "type": "string",
      "maxLength": 15,
      "default": "scene",
      "description": "UI module to display when this scene loads (e.g. scene, buttons)"
    },
    "device_id": {
      "type": "string",
      "maxLength": 64,
      "description": "Device slug"
    },
    "program_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Program change value for this scene (0-127)"
    },
    "bank_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 127,
      "default": 0,
      "description": "Bank number for this scene (0-127, used when bank_select_mode is enabled)"
    },
    "send_pc_on_load": {
      "type": "boolean",
      "default": true,
      "description": "Send program change when loading this scene"
    },
    "on_load": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions to execute when scene loads (for pedal initialization)"
    },
    "touchwheel_mode": {
      "type": "string",
      "enum": ["pads", "program_change", "continuous", "set_tempo", "pitch_bend", "aftertouch", "double_cc", "velocity"],
      "default": "pads",
      "description": "Touchwheel behavior mode"
    },
    "touchwheel_style": {
      "type": "string",
      "enum": ["odometer", "endless", "bipolar"],
      "default": "odometer",
      "description": "Touchwheel style: odometer (~15 positions), endless (full range), bipolar (pitch bend only)"
    },
    "touchwheel": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Touchwheel continuous mapping (for TOUCHWHEEL_MODE_CONTINUOUS)"
    },
    "touchpads": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "description": "Array of 12 touchpad mappings",
      "items": {
        "$ref": "#/definitions/touchpad_mapping"
      }
    },
    "button_left": {
      "$ref": "#/definitions/action_chain"
    },
    "button_right": {
      "$ref": "#/definitions/action_chain"
    },
    "button_both": {
      "$ref": "#/definitions/action_chain"
    },
    "bump": {
      "$ref": "#/definitions/action_chain",
      "description": "Bump sensor action chain"
    },
    "expression": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Expression pedal mapping"
    },
    "cv": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "CV input mapping"
    },
    "proximity": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Proximity sensor mapping"
    },
    "als": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "Ambient light sensor mapping"
    },
    "expression_mode": {
      "type": "string",
      "enum": ["expression", "sustain", "sostenuto", "gate", "switch"],
      "default": "expression",
      "description": "Expression jack operating mode"
    },
    "sustain": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sustain events (default: CC64 toggle)"
    },
    "sostenuto": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for sostenuto events (default: CC66 toggle)"
    },
    "expr_switch": {
      "$ref": "#/definitions/action_chain",
      "description": "Actions for expression switch mode (up to 8 arbitrary actions)"
    },
    "cv_input_mode": {
      "type": "string",
      "enum": ["none", "cv", "clock_sync", "audio", "note"],
      "default": "cv",
      "description": "CV input interpretation mode"
    },
    "cv_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for CV NOTE input mode"
    },
    "cv_velocity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 127,
      "default": 100,
      "description": "Fixed velocity value for CV NOTE mode"
    },
    "expression_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for expression note output"
    },
    "proximity_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for proximity note output"
    },
    "als_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for ambient light sensor note output"
    },
    "audio_config": {
      "type": "object",
      "description": "Audio envelope follower configuration (when cv_input_mode=audio)",
      "properties": {
        "range": {
          "type": "string",
          "enum": ["bi5v", "bi10v"],
          "default": "bi5v",
          "description": "Input voltage range for audio (bipolar ranges only)"
        },
        "sensitivity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 128,
          "description": "Gain (0-255 maps to 0.25x-64x exponential curve, set by calibration)"
        },
        "attack_ms": {
          "type": "integer",
          "minimum": 5,
          "maximum": 100,
          "default": 10,
          "description": "Envelope attack time in milliseconds"
        },
        "release_ms": {
          "type": "integer",
          "minimum": 50,
          "maximum": 2000,
          "default": 200,
          "description": "Envelope release time in milliseconds"
        },
        "threshold": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 5,
          "description": "Noise gate threshold (0=off, 1-127=increasing gate)"
        },
        "polarity": {
          "type": "string",
          "enum": ["attract", "repel"],
          "default": "attract",
          "description": "Output polarity (attract=louder is higher, repel=louder is lower/ducking)"
        }
      }
    },
    "bpm": {
      "type": "integer",
      "minimum": 20,
      "maximum": 300,
      "default": 120,
      "description": "Tempo in beats per minute for this scene"
    },
    "clock_source": {
      "type": "string",
      "enum": ["internal", "midi", "sync"],
      "default": "internal",
      "description": "Tempo clock source for this scene"
    },
    "beat_divider": {
      "type": "string",
      "enum": ["quarter", "eighth", "sixteenth"],
      "default": "quarter",
      "description": "Beat division for this scene (what note value triggers beat events)"
    },
    "time_signature": {
      "type": "object",
      "description": "Time signature for this scene",
      "properties": {
        "numerator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beats per bar"
        },
        "denominator": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 4,
          "description": "Beat unit (4 = quarter note)"
        }
      }
    },
    "use_transport": {
      "type": "boolean",
      "default": false,
      "description": "When true, animation follows transport controls (play/pause/stop). When false, animation always runs at current BPM."
    },
    "send_clock": {
      "type": "boolean",
      "default": true,
      "description": "When true, scene sends MIDI clock messages. When false, no MIDI clock is sent regardless of tempo settings."
    },
    "lfo1_config": {
      "$ref": "#/definitions/lfo_config",
      "description": "LFO1 waveform and rate configuration"
    },
    "lfo2_config": {
      "$ref": "#/definitions/lfo_config",
      "description": "LFO2 waveform and rate configuration"
    },
    "lfo1": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "LFO1 output mapping (CC/note, curve, polarity)"
    },
    "lfo2": {
      "$ref": "#/definitions/continuous_mapping",
      "description": "LFO2 output mapping (CC/note, curve, polarity)"
    },
    "lfo1_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for LFO1 note output"
    },
    "lfo2_velocity_mode": {
      "type": "string",
      "enum": ["fixed", "gate_voltage", "touchwheel"],
      "default": "fixed",
      "description": "Velocity mode for LFO2 note output"
    }
  },
  "definitions": {
    "continuous_mapping": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "output_type": {
          "type": "string",
          "enum": ["cc", "note"],
          "default": "cc",
          "description": "Output type (cc or note)"
        },
        "cc_number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "description": "Primary MIDI CC number (when output_type=cc)"
        },
        "cc_numbers": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 127 },
          "maxItems": 4,
          "description": "Additional CC numbers for simultaneous control (up to 4 total)"
        },
        "base_note": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 60,
          "description": "Base MIDI note, typically middle C (when output_type=note)"
        },
        "note_range": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 24,
          "description": "Range in semitones (when output_type=note)"
        },
        "velocity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 127,
          "default": 100,
          "description": "Note velocity (when output_type=note)"
        },
        "note_latch": {
          "type": "boolean",
          "default": false,
          "description": "When true, notes hold until release timer expires (when output_type=note)"
        },
        "note_release_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 4000,
          "default": 500,
          "description": "Release delay in ms when latch is on (when output_type=note)"
        },
        "polyphony": {
          "type": "string",
          "enum": ["mono", "poly"],
          "default": "mono",
          "description": "Polyphony mode: mono (single voice) or poly (up to 4 voices)"
        },
        "curve_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "description": "Curve type (0=linear, 1=exp, 2=log, 3=s-curve, etc.)"
        },
        "curve_slope": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Curve intensity (0=gentle, 1=medium, 2=steep)"
        },
        "polarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "description": "Polarity (0=unipolar, 1=bipolar, 2=inverted)"
        },
        "min_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 0
        },
        "max_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 127
        },
        "use_idle_value": {
          "type": "boolean",
          "default": false
        },
        "idle_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 64,
          "description": "Idle value (64 for CC bipolar, 60 for NOTE mode)"
        },
        "idle_timeout_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 10000,
          "default": 1000
        }
      }
    },
    "lfo_config": {
      "type": "object",
      "description": "LFO waveform and rate configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether this LFO is active"
        },
        "waveform": {
          "type": "string",
          "enum": ["sine", "triangle", "square", "saw_up", "saw_down", "sample_hold", "custom"],
          "default": "sine",
          "description": "LFO waveform shape"
        },
        "rate_mode": {
          "type": "string",
          "enum": ["free", "tempo", "touchwheel", "expression", "cv", "als", "proximity"],
          "default": "free",
          "description": "Rate mode: free (Hz-based), tempo (note division sync), touchwheel, expression, cv, als, or proximity (sensor-controlled)"
        },
        "start_mode": {
          "type": "string",
          "enum": ["running", "paused", "transport"],
          "default": "running",
          "description": "Start mode: running (starts when scene loads), paused (requires action to start), or transport (follows transport state)"
        },
        "trigger_timing": {
          "type": "string",
          "enum": ["immediate", "beat", "bar"],
          "default": "immediate",
          "description": "When LFO Start action is triggered: immediate (start now), beat (wait for next beat), bar (wait for bar start)"
        },
        "repeat": {
          "type": "boolean",
          "default": true,
          "description": "When true, LFO loops infinitely. When false, runs one cycle and stops (one-shot mode)."
        },
        "reset_phase": {
          "type": "boolean",
          "default": true,
          "description": "When true, LFO restarts from beginning on enable. When false, continues from previous position."
        },
        "restore_on_stop": {
          "type": "boolean",
          "default": false,
          "description": "When true, sends the waveform's starting value (phase 0) when LFO stops."
        },
        "rate_hz": {
          "type": "number",
          "minimum": 0.05,
          "maximum": 20.0,
          "default": 1.0,
          "description": "Free-running rate in Hz (when rate_mode=free)"
        },
        "division": {
          "type": "string",
          "enum": ["16_bars", "12_bars", "8_bars", "4_bars", "2_bars", "1_bar", "half", "quarter", "eighth", "sixteenth", "32nd"],
          "default": "quarter",
          "description": "Tempo-synced note division (when rate_mode=tempo)"
        },
        "phase_offset": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 0,
          "description": "Phase offset (0-255 = 0-360 degrees)"
        },
        "duty_cycle": {
          "type": "integer",
          "minimum": 0,
          "maximum": 127,
          "default": 64,
          "description": "Square wave duty cycle (0-127 = 0-100%)"
        }
      }
    },
    "touchpad_mapping": {
      "type": "object",
      "required": ["enabled", "actions"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether this touchpad is active"
        },
        "actions": {
          "$ref": "#/definitions/action_chain"
        }
      }
    },
    "action_chain": {
      "type": "array",
      "maxItems": 4,
      "description": "Array of actions to execute (max 4)",
      "items": {
        "$ref": "#/definitions/action"
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "preset_inc",
            "preset_dec",
            "preset",
            "preset_hold",
            "preset_cycle",
            "scene_inc",
            "scene_dec",
            "scene",
            "play",
            "stop",
            "pause",
            "record",
            "tap",
            "tap_tempo",
            "set_tempo",
            "tempo_inc",
            "tempo_dec",
            "tempo_hold",
            "tempo_cycle",
            "control_change",
            "control_hold",
            "control_cycle",
            "note",
            "randomize",
            "confirm_pending",
            "reset",
            "sustain",
            "sostenuto",
            "touchwheel_hold",
            "touchwheel_cycle",
            "lfo_start",
            "lfo_stop",
            "lfo_toggle",
            "lfo_shape",
            "clock_toggle",
            "clock_hold",
            "clock_burst",
            "cut_toggle",
            "cut_hold",
            "set_ui",
            "ui_hold",
            "ui_cycle"
          ],
          "description": "Action type name"
        },
        "timing": {
          "type": "string",
          "pattern": "^(immediate|beat|beat_[1-9]|beat_1[0-6])$",
          "default": "immediate",
          "description": "When action takes effect: immediate (default), beat (next beat), beat_N (specific beat 1-16)"
        },
        "repeat": {
          "type": "boolean",
          "default": false,
          "description": "Whether action repeats at the specified division"
        },
        "repeat_division": {
          "type": "string",
          "enum": ["16_bars", "12_bars", "8_bars", "4_bars", "2_bars", "1_bar", "half", "quarter", "eighth", "sixteenth", "32nd"],
          "default": "quarter",
          "description": "Repeat interval (only used when repeat=true)"
        },
        "probability": {
          "type": "integer",
          "minimum": 10,
          "maximum": 100,
          "multipleOf": 10,
          "default": 100,
          "description": "Chance of firing on each repeat (10-100%, only used when repeat=true)"
        },
        "pattern_length": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8,
          "default": 0,
          "description": "Step pattern length (0=disabled, 2-8=enabled, only used when repeat=true)"
        },
        "pattern_mask": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 255,
          "description": "Bitmask of active steps (bit 0=step 1, only used when pattern_length>=2)"
        },
        "morph": {
          "type": "boolean",
          "default": false,
          "description": "Enable smooth value transition (for control_hold, control_cycle, randomize)"
        },
        "morph_steps": {
          "type": "string",
          "enum": ["auto", "coarse", "medium", "fine", "manual"],
          "default": "auto",
          "description": "Step resolution for morph: auto (smart), coarse (8), medium (16), fine (32), manual"
        },
        "morph_manual_steps": {
          "type": "integer",
          "minimum": 8,
          "maximum": 128,
          "default": 32,
          "description": "Custom step count when morph_steps=manual"
        },
        "morph_timing": {
          "type": "string",
          "enum": ["feel", "duration", "sync"],
          "default": "feel",
          "description": "Timing mode: feel (curated), duration (lasts FOR N), sync (ends ON moment)"
        },
        "morph_feel": {
          "type": "string",
          "enum": ["fast", "medium", "slow"],
          "default": "medium",
          "description": "Curated feel preset (when morph_timing=feel)"
        },
        "morph_division": {
          "type": "string",
          "enum": ["beat", "bar", "2_bars", "4_bars", "beat_2", "beat_3", "beat_4"],
          "default": "bar",
          "description": "Musical division (when morph_timing=duration or sync)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {"enum": ["control_change", "control_hold", "control_cycle"]}
            }
          },
          "then": {
            "required": ["cc"],
            "properties": {
              "cc": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single MIDI CC number"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of MIDI CC numbers (multi-CC)"
                  }
                ]
              },
              "value": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single CC value"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of CC values (multi-CC)"
                  }
                ]
              },
              "value2": {
                "oneOf": [
                  {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 127,
                    "description": "Single release value for hold"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Array of release values (multi-CC hold)"
                  }
                ]
              },
              "values": {
                "oneOf": [
                  {
                    "type": "array",
                    "minItems": 2,
                    "maxItems": 8,
                    "items": {"type": "integer", "minimum": 0, "maximum": 127},
                    "description": "Cycle values for single CC"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "items": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 8,
                      "items": {"type": "integer", "minimum": 0, "maximum": 127}
                    },
                    "description": "Array of cycle values (multi-CC cycle)"
                  }
                ]
              },
              "current_index": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "default": 0,
                "description": "Current position in cycle"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["note"]}
            }
          },
          "then": {
            "required": ["note"],
            "properties": {
              "note": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "description": "MIDI note number"
              },
              "velocity": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "default": 100,
                "description": "Note velocity"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "scene"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 1,
                "maximum": 128,
                "description": "Scene number (1-128)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset"}
            }
          },
          "then": {
            "required": ["number"],
            "properties": {
              "number": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Program number (0-127 without bank, 0-16383 with bank mode)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "randomize"}
            }
          },
          "then": {
            "required": ["cc_numbers"],
            "properties": {
              "cc_numbers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "description": "CC numbers to randomize (0-127)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset_hold"}
            }
          },
          "then": {
            "required": ["press_preset", "release_preset"],
            "properties": {
              "press_preset": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Preset to set on press"
              },
              "release_preset": {
                "type": "integer",
                "minimum": 0,
                "maximum": 16383,
                "description": "Preset to set on release"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "preset_cycle"}
            }
          },
          "then": {
            "required": ["num_presets", "presets"],
            "properties": {
              "num_presets": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of presets in cycle"
              },
              "presets": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 16383
                },
                "description": "Preset values to cycle through"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "tempo_hold"}
            }
          },
          "then": {
            "required": ["press_bpm", "release_bpm"],
            "properties": {
              "press_bpm": {
                "type": "integer",
                "minimum": 20,
                "maximum": 300,
                "description": "Tempo to set on press (BPM)"
              },
              "release_bpm": {
                "type": "integer",
                "minimum": 20,
                "maximum": 300,
                "description": "Tempo to set on release (BPM)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "tempo_cycle"}
            }
          },
          "then": {
            "required": ["num_tempos", "tempos"],
            "properties": {
              "num_tempos": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of tempos in cycle"
              },
              "tempos": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 20,
                  "maximum": 300
                },
                "description": "Tempo values (BPM) to cycle through"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "touchwheel_hold"}
            }
          },
          "then": {
            "required": ["mode", "mode2"],
            "properties": {
              "mode": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "description": "User-facing touchwheel mode index on press"
              },
              "mode2": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7,
                "description": "User-facing touchwheel mode index on release"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "touchwheel_cycle"}
            }
          },
          "then": {
            "required": ["num_modes", "modes"],
            "properties": {
              "num_modes": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of modes in cycle"
              },
              "modes": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 7
                },
                "description": "User-facing touchwheel mode indices to cycle through"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["clock_toggle", "clock_hold"]}
            }
          },
          "then": {
            "properties": {
              "start_enabled": {
                "type": "boolean",
                "default": false,
                "description": "For toggle: first press disables clock (since clock runs by default). For hold: press disables clock."
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "clock_burst"}
            }
          },
          "then": {
            "properties": {
              "speed_percent": {
                "type": "integer",
                "enum": [25, 50, 75, 100, 125, 150, 175, 200, 225, 250, 275, 300],
                "default": 100,
                "description": "Speed multiplier for burst (25-300% in 25% increments)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"enum": ["cut_toggle", "cut_hold"]}
            }
          },
          "then": {
            "properties": {
              "cut_mode": {
                "type": "string",
                "enum": ["local", "passthrough", "both"],
                "default": "both",
                "description": "What to cut: local (device-generated), passthrough (MIDI IN), or both"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "confirm_pending"}
            }
          },
          "then": {
            "properties": {
              "confirm_target": {
                "type": "string",
                "enum": ["preset", "scene"],
                "default": "preset",
                "description": "What to confirm in Advanced mode: preset change or scene change"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "set_ui"}
            }
          },
          "then": {
            "required": ["module"],
            "properties": {
              "module": {
                "type": "integer",
                "minimum": 0,
                "description": "Index into scene-selectable UI modules list"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "ui_hold"}
            }
          },
          "then": {
            "required": ["module", "module2"],
            "properties": {
              "module": {
                "type": "integer",
                "minimum": 0,
                "description": "UI module index on press"
              },
              "module2": {
                "type": "integer",
                "minimum": 0,
                "description": "UI module index on release"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {"const": "ui_cycle"}
            }
          },
          "then": {
            "required": ["num_modules", "modules"],
            "properties": {
              "num_modules": {
                "type": "integer",
                "minimum": 2,
                "maximum": 8,
                "description": "Number of UI modules in cycle"
              },
              "modules": {
                "type": "array",
                "minItems": 2,
                "maxItems": 8,
                "items": {
                  "type": "integer",
                  "minimum": 0
                },
                "description": "UI module indices to cycle through"
              }
            }
          }
        }
      ]
    }
  }
}

